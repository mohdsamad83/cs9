# Husky pre-commit hook: enforce ESLint on staged frontend files.
# Auto-installed via the frontend "prepare" script on `npm install`.
# Lints only staged frontend JS/TS files, so non-frontend commits aren't blocked.
# Bypass in emergencies with: git commit --no-verify

# Staged (Added/Copied/Modified/Renamed) JS/TS files under frontend/
staged=$(git diff --cached --name-only --diff-filter=ACMR \
  | grep -E '^frontend/.*\.(js|jsx|ts|tsx)$' || true)

[ -z "$staged" ] && exit 0

# Strip the leading "frontend/" so paths are relative to the ESLint config root.
rel=$(printf '%s\n' "$staged" | sed 's#^frontend/##')

echo "▶ pre-commit: linting staged frontend file(s)…"
cd frontend || {
  echo "✖ pre-commit: could not enter frontend/"; exit 1;
}

# shellcheck disable=SC2086  # intentional word-splitting of the file list
if ! npx --no-install eslint $rel; then
  echo ""
  echo "✖ ESLint failed. Fix the errors above (try: cd frontend && npx eslint --fix <files>),"
  echo "  re-stage, and commit again. To bypass in an emergency: git commit --no-verify"
  exit 1
fi

echo "✓ pre-commit: lint passed."
